"""Generated multi-service webapp runtime.

Produced by ``cyber_webapp.codegen`` from a WorldGraph + manifest. Hand
edits will be overwritten by the next build. The flag value is NOT in
this file; ``seed.json`` is loaded into an in-memory SQLite database at
startup, then deleted from disk before the server begins accepting
requests.
"""
from __future__ import annotations

import argparse
import base64
import io
import json
import os
import posixpath
import re
import shlex
import sqlite3
import xml.sax
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from jinja2.sandbox import SandboxedEnvironment
from pathlib import Path
from urllib.error import URLError
from urllib.parse import parse_qs, quote, urlparse
from urllib.request import urlopen


class _RealFiles:
    # Real-filesystem backing for the ``files`` surface (the CONTAINER backing). Same
    # get / contains / subscript access the in-memory dict offers, but every read is a
    # real ``open()`` against the container fs — so a traversal escape or a ``cat``
    # reaches the real filesystem, not a dict. A real fs is not a finite, enumerable
    # map, so iteration / len are intentionally unsupported.
    def get(self, path, default=None):
        data = self._read(path)
        return default if data is None else data

    def __getitem__(self, path):
        data = self._read(path)
        if data is None:
            raise KeyError(path)
        return data

    def __contains__(self, path):
        return self._read(path) is not None

    @staticmethod
    def _read(path):
        try:
            with open(path, "rb") as handle:
                return handle.read().decode("utf-8", "replace")
        except OSError:
            return None


def _materialize_files(files: dict) -> None:
    # Write the seed's file map onto the REAL container filesystem at its own paths, so
    # the handlers' real open() finds them and a traversal escape genuinely climbs it.
    for path, content in files.items():
        target = Path(path)
        if str(target.parent) not in ("", "."):
            target.parent.mkdir(parents=True, exist_ok=True)
        target.write_text(str(content), encoding="utf-8")


def _load_seed_and_init_state(seed_path: Path) -> dict:
    raw = seed_path.read_text(encoding="utf-8")
    seed_path.unlink()
    payload = json.loads(raw)
    schema = payload["schema"]
    table = schema["table"]
    key_col = schema["key_column"]
    value_col = schema["value_column"]

    db = sqlite3.connect(":memory:", check_same_thread=False)
    db.row_factory = sqlite3.Row
    cursor = db.cursor()
    cursor.execute(
        f"CREATE TABLE {table} ({key_col} TEXT PRIMARY KEY, {value_col} TEXT)",
    )
    for record_key, fields in payload["records"].items():
        cursor.execute(
            f"INSERT INTO {table} ({key_col}, {value_col}) VALUES (?, ?)",
            (record_key, fields.get(value_col, "")),
        )
    db.commit()

    # OPENRANGE_REALFS (set by the CONTAINER backing) flips the file surface from the
    # in-memory dict to a real filesystem — the PROCESS backing leaves it unset and
    # stays byte-for-byte the in-memory emulation.
    files = payload.get("files", {})
    if os.environ.get("OPENRANGE_REALFS"):
        _materialize_files(files)
        files = _RealFiles()

    return {
        "db": db,
        "secrets": payload["secrets"],
        "files": files,
        "schema": schema,
        "guarded": payload.get("guarded", {}),
    }


def _value_variants(value):
    raw = value.encode()
    b64 = base64.b64encode(raw).decode()
    return {value, b64, b64.rstrip("="), raw.hex(), quote(value, safe="")}


def _scan_leaks(body, guarded):
    # Which guarded (HIDDEN) values reached this response. Records node IDS ONLY —
    # never the secret value — so the request log cannot be grepped for the flag.
    # Mirrors cyber_webapp.consequence.value_variants (literal + base64/hex/url) so
    # the live verdict matches the offline one; containment de-dup is offline-only.
    text = body.decode("utf-8", "replace") if isinstance(body, bytes) else str(body)
    return sorted(
        nid
        for nid, value in guarded.items()
        if value and any(var in text for var in _value_variants(value))
    )


{% for handler in handlers %}
# {{ handler.docstring }}
def {{ handler.name }}(query, state):
{{ handler.body }}

{% endfor %}

_DISCOVERY = {{ discovery | tojson }}


def _index(query, state):
    del query, state
    return 200, {"Content-Type": "text/html"}, _index_html()


def _index_html() -> bytes:
    title = _DISCOVERY.get("title", "Service")
    body = (
        f"<!doctype html><html><head><title>{title}</title></head>"
        f"<body><h1>{title}</h1><p>OK</p></body></html>"
    )
    return body.encode()


def _openapi(query, state):
    del query, state
    return (
        200,
        {"Content-Type": "application/json"},
        json.dumps(_DISCOVERY).encode(),
    )


ROUTES = {
{% for route in routes %}
    {{ route.path | tojson }}: {{ route.handler }},
{% endfor %}
}
ROUTES.setdefault("/", _index)
ROUTES.setdefault("/openapi.json", _openapi)

# Internal endpoints, dispatched to only by the SSRF proxy — never served to a direct
# request. This table enforces network segmentation when one process holds the whole
# world; empty under CONTAINER, where each service is its own host.
INTERNAL_ROUTES = {
{% for route in internal_routes %}
    {{ route.path | tojson }}: {{ route.handler }},
{% endfor %}
}

# Each route's required HTTP method. A body-shaped endpoint is mounted as POST and
# rejects GET, so an exploit must be delivered with the right request shape (a body),
# not as a query string. Paths absent here (index, discovery) default to GET.
_ROUTE_METHODS = {
{% for route in routes %}
    {{ route.path | tojson }}: {{ (route.method | default("GET")) | tojson }},
{% endfor %}
}


class Handler(BaseHTTPRequestHandler):
    server: WebappServer  # type: ignore[name-defined]

    def do_GET(self) -> None:
        parsed = urlparse(self.path)
        self._dispatch(parsed.path, parse_qs(parsed.query, keep_blank_values=True))

    def do_POST(self) -> None:
        parsed = urlparse(self.path)
        query = parse_qs(parsed.query, keep_blank_values=True)
        for key, values in self._read_body().items():
            query.setdefault(key, []).extend(values)
        self._dispatch(parsed.path, query)

    def _read_body(self):
        # Body params are exposed in the same name->[value] shape parse_qs yields, so a
        # handler reads its inputs identically whether they arrive as a GET query, a
        # POST form body, or a JSON body -- only the request shape differs, not the code.
        try:
            length = int(self.headers.get("Content-Length") or 0)
        except ValueError:
            length = 0
        raw = self.rfile.read(length) if length > 0 else b""
        text = raw.decode("utf-8", "replace")
        content_type = (self.headers.get("Content-Type") or "").split(";")[0].strip()
        if content_type == "application/json":
            try:
                data = json.loads(text or "{}")
            except ValueError:
                return {}
            if not isinstance(data, dict):
                return {}
            return {
                str(k): [str(v) for v in value]
                if isinstance(value, list)
                else [str(value)]
                for k, value in data.items()
            }
        return parse_qs(text, keep_blank_values=True)

    def _dispatch(self, path, query) -> None:
        handler = ROUTES.get(path)
        if handler is None:
            self.respond_simple(404, "text/plain", b"not found\n")
            return
        if self.command != _ROUTE_METHODS.get(path, "GET"):
            self.respond_simple(405, "text/plain", b"method not allowed\n")
            return
        try:
            status, headers, body = handler(query, self.server.state)
        except Exception as exc:  # noqa: BLE001
            self.respond_simple(500, "text/plain", str(exc).encode())
            return
        self.respond(status, headers, body)

    def respond(self, status, headers, body):
        leaked = _scan_leaks(body, self.server.state.get("guarded", {}))
        self.server.log_access(self.command, self.path, status, leaked)
        content_type = headers.get("Content-Type", "application/octet-stream")
        self.send_response(status)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body)

    def respond_simple(self, status, content_type, body):
        self.respond(status, {"Content-Type": content_type}, body)

    def log_message(self, format, *args):
        return


class WebappServer(ThreadingHTTPServer):
    def __init__(self, address, *, log_path, state):
        super().__init__(address, Handler)
        self.log_path = log_path
        self.state = state

    def log_access(self, method, path, status, leaked=()):
        row = {"method": method, "path": path, "status": status}
        if leaked:
            row["leaked"] = list(leaked)
        with self.log_path.open("a", encoding="utf-8") as handle:
            handle.write(json.dumps(row, sort_keys=True) + "\n")


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--host", default="127.0.0.1")
    parser.add_argument("--port", type=int, default=0)
    parser.add_argument("--log", type=Path, required=True)
    parser.add_argument("--seed", type=Path, default=Path(__file__).parent / "seed.json")
    args = parser.parse_args()

    args.log.parent.mkdir(parents=True, exist_ok=True)
    args.log.write_text("", encoding="utf-8")

    state = _load_seed_and_init_state(args.seed)

    server = WebappServer((args.host, args.port), log_path=args.log, state=state)
    host, port = server.server_address[0], server.server_address[1]
    print(json.dumps({"host": host, "port": port}), flush=True)
    server.serve_forever()


if __name__ == "__main__":
    main()
